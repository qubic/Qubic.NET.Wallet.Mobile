@inherits LayoutComponentBase
@inject SeedSessionService Seed
@inject TickMonitorService TickMonitor
@inject BalanceService BalanceSvc
@inject VaultService Vault
@inject WalletStorageService WalletStorage
@inject TransactionTrackerService TxTracker
@inject NavigationManager Nav
@inject QubicSettingsService Settings
@inject IJSRuntime JS
@implements IDisposable

<div class="qb-app">
    <!-- Top Bar -->
    <header class="qb-topbar">
        <img src="qubic-icon.svg" alt="Qubic" class="qb-topbar-icon" />

        <div class="qb-topbar-center">
            @if (Seed.HasSeed)
            {
                <span class="badge-qb-cyan qb-wallet-badge" @onclick="ToggleWalletMenu" title="Switch wallet">
                    @WalletDisplayName
                    @if (Vault.IsUnlocked && Vault.Entries.Count > 1)
                    {
                        <i class="bi bi-chevron-down" style="font-size:0.55rem;margin-left:0.15rem"></i>
                    }
                </span>
                <span class="mono qb-topbar-balance">
                    @FormatBalance(BalanceSvc.Balance)
                </span>

                @if (_showWalletMenu && Vault.IsUnlocked && Vault.Entries.Count > 1)
                {
                    <div class="qb-wallet-dropdown">
                        @foreach (var entry in Vault.Entries)
                        {
                            var isActive = entry.Identity == Seed.Identity?.ToString();
                            <div class="qb-wallet-dropdown-item @(isActive ? "active" : "")"
                                 @onclick="() => SwitchToEntry(entry)">
                                <div class="fw-bold small">@entry.Label</div>
                                <div class="mono" style="font-size:0.6rem;color:var(--qb-text-muted)">@FormatId(entry.Identity)</div>
                            </div>
                        }
                    </div>
                }
            }
        </div>

        <div class="qb-topbar-end">
            @if (TickMonitor.IsConnected)
            {
                <span class="badge-qb-success qb-connection-badge" @onclick="ToggleTickInfo" title="Connected">
                    <i class="bi bi-wifi"></i>
                </span>
            }
            else
            {
                <span class="badge-qb-warning qb-connection-badge" title="Offline">
                    <i class="bi bi-wifi-off"></i>
                </span>
            }
        </div>

        @if (_showTickInfo && TickMonitor.IsConnected)
        {
            <div class="qb-tick-popup">
                <span class="mono small">Epoch @(TickMonitor.Epoch) &middot; Tick @(TickMonitor.Tick)</span>
            </div>
        }
    </header>

    <!-- Page Content -->
    <main class="qb-content" id="qb-content" @onclick="CloseOverlays">
        <ErrorBoundary @ref="_errorBoundary">
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent>
                <div class="d-flex flex-column align-items-center justify-content-center py-5">
                    <i class="bi bi-exclamation-triangle-fill text-warning" style="font-size:3rem"></i>
                    <h5 class="mt-3">Something went wrong</h5>
                    <p class="text-muted small">An error occurred while rendering this page.</p>
                    <button class="btn btn-primary" @onclick="RecoverFromError">
                        <i class="bi bi-arrow-clockwise me-1"></i>Reload
                    </button>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </main>

    <!-- Bottom Tab Bar -->
    <TabBar />
</div>

@code {
    ErrorBoundary? _errorBoundary;
    bool _showWalletMenu;
    bool _showTickInfo;

    string WalletDisplayName
    {
        get
        {
            var id = Seed.Identity?.ToString();
            var idSnippet = id != null ? $"({id[..4]}...{id[^4..]})" : "";
            if (Seed.ActiveLabel != null)
                return $"{Seed.ActiveLabel} {idSnippet}";
            return idSnippet;
        }
    }

    static string FormatId(string id) => id.Length >= 8 ? $"{id[..4]}...{id[^4..]}" : id;

    static string FormatBalance(long? balance)
    {
        if (balance is not { } b) return "—";
        return b switch
        {
            >= 1_000_000_000 => $"{b / 1_000_000_000.0:0.#} bQU",
            >= 1_000_000 => $"{b / 1_000_000.0:0.#} mQU",
            _ => $"{b:N0} QU"
        };
    }

    void ToggleWalletMenu()
    {
        if (Vault.IsUnlocked && Vault.Entries.Count > 1)
            _showWalletMenu = !_showWalletMenu;
        _showTickInfo = false;
    }

    void ToggleTickInfo()
    {
        _showTickInfo = !_showTickInfo;
        _showWalletMenu = false;
    }

    void CloseOverlays()
    {
        if (_showWalletMenu) _showWalletMenu = false;
        if (_showTickInfo) _showTickInfo = false;
    }

    void RecoverFromError()
    {
        _errorBoundary?.Recover();
        Nav.NavigateTo("/", forceLoad: false);
    }

    void SwitchToEntry(VaultEntry entry)
    {
        _showWalletMenu = false;
        if (entry.Identity == Seed.Identity?.ToString()) return;

        WalletStorage.ClearSeed();
        TxTracker.ClearEncryptionKey();
        Seed.SetSeed(entry.Seed, entry.Label);
        WalletStorage.SetSeed(entry.Seed, entry.Identity, TickMonitor.Epoch);
        TxTracker.SetEncryptionKey(entry.Seed);
    }

    protected override void OnInitialized()
    {
        TickMonitor.OnTickChanged += OnStateChanged;
        Seed.OnSeedChanged += OnStateChanged;
        Vault.OnVaultChanged += OnStateChanged;
        BalanceSvc.OnBalanceChanged += OnStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var saved = Settings.GetCustom<string>("theme");
            if (!string.IsNullOrEmpty(saved) && saved != "dark")
                await JS.InvokeVoidAsync("setTheme", saved);
        }
    }

    void OnStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        TickMonitor.OnTickChanged -= OnStateChanged;
        Seed.OnSeedChanged -= OnStateChanged;
        Vault.OnVaultChanged -= OnStateChanged;
        BalanceSvc.OnBalanceChanged -= OnStateChanged;
    }
}
