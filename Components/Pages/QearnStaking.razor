@page "/qearn"
@implements IDisposable
@using Qubic.Core.Contracts.Qearn
@inject QubicBackendService Backend
@inject SeedSessionService Seed
@inject TickMonitorService TickMonitor
@inject TransactionTrackerService TxTracker
@inject QubicSettingsService Settings
@inject IJSRuntime JS

<h4>QEarn Staking</h4>
<p class="text-muted small">Lock QU to earn rewards over 52 weeks.</p>

@if (!Seed.HasSeed)
{
    <div class="alert alert-warning">Enter a seed first.</div>
}
else
{
    @* ── Active locks summary ── *@
    @if (_autoLoading)
    {
        <div class="text-muted small mb-3">
            <span class="spinner-border spinner-border-sm me-1"></span> Loading your staking info...
        </div>
    }
    else if (_activeLocks.Count > 0 || _autoEndedStatus != null)
    {
        <div class="card mb-3 border-primary">
            <div class="card-body py-2">
                <div class="fw-bold small mb-2">Your Staking Summary</div>

                @foreach (var l in _activeLocks)
                {
                    var yieldPct = l.Yield > 0 ? (double)l.Yield / 100_000 : 0;
                    var earlyPct = GetEarlyUnlockRewardPercent(l.Week);
                    var earlyReward = l.EstReward * (ulong)earlyPct / 100;
                    var lk = l;

                    <div class="card mb-2">
                        <div class="card-body py-2 px-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="fw-bold small">Epoch @l.Epoch</span>
                                <span class="badge bg-primary">Week @l.Week / 52</span>
                            </div>

                            <div class="row g-1 small">
                                <div class="col-6">
                                    <span class="text-muted">Locked:</span>
                                    <span class="mono">@l.Amount.ToString("N0")</span>
                                </div>
                                <div class="col-6">
                                    <span class="text-muted">Remaining:</span>
                                    <span>@l.Remaining wk@(l.Remaining != 1 ? "s" : "")</span>
                                </div>
                                <div class="col-6">
                                    <span class="text-muted">Yield:</span>
                                    <span class="mono">@(l.Yield > 0 ? $"{yieldPct:F2}%" : "\u2014")</span>
                                </div>
                                <div class="col-6">
                                    <span class="text-muted">Est. reward:</span>
                                    <span class="mono text-success">@(l.EstReward > 0 ? $"+{l.EstReward:N0}" : "\u2014")</span>
                                </div>
                                @if (l.EpochCurrentLocked > 0)
                                {
                                    <div class="col-12">
                                        <span class="text-muted">Epoch total:</span>
                                        <span class="mono text-muted" title="@(l.EpochCurrentLocked.ToString("N0")) QU currently locked (bonus: @(l.EpochBonusAmount.ToString("N0")) QU)">
                                            @(l.EpochCurrentLocked.ToString("N0")) QU
                                        </span>
                                    </div>
                                }
                                @if (l.EstReward > 0)
                                {
                                    <div class="col-12">
                                        <span class="text-muted">Early unlock:</span>
                                        <span class="mono @(earlyPct < 100 ? "text-warning" : "text-success")">
                                            +@earlyReward.ToString("N0") QU (@earlyPct%)
                                        </span>
                                    </div>
                                }
                            </div>

                            @* Unlock button / inline editor *@
                            <div class="mt-2">
                                @if (_unlockingEpoch == l.Epoch && !_sending)
                                {
                                    <div class="d-flex align-items-center gap-1">
                                        <input type="text" inputmode="numeric" class="form-control form-control-sm flex-fill"
                                               value="@FormatQu((long)_unlockAmount)"
                                               @onchange="e => _unlockAmount = (ulong)ParseQu(e.Value?.ToString())" />
                                        <button class="btn btn-sm btn-warning" @onclick="() => ConfirmUnlock(lk)">OK</button>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _unlockingEpoch = null">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-warning w-100" @onclick="() => StartUnlock(lk)"
                                            disabled="@(_sending)">
                                        @(_unlockingEpoch == l.Epoch && _sending ? "Unlocking..." : "Unlock")
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }

                @* Ended status rows *@
                @if (_autoEndedStatus != null)
                {
                    var es = _autoEndedStatus.Value;
                    @if (es.fullyUnlocked > 0)
                    {
                        <div class="small text-success mb-1">
                            Fully unlocked: <strong>@es.fullyUnlocked.ToString("N0") QU</strong>
                            &mdash; rewarded: <strong>@es.fullyRewarded.ToString("N0") QU</strong>
                        </div>
                    }
                    @if (es.earlyUnlocked > 0)
                    {
                        <div class="small text-warning mb-1">
                            Early unlocked: <strong>@es.earlyUnlocked.ToString("N0") QU</strong>
                            &mdash; rewarded: <strong>@es.earlyRewarded.ToString("N0") QU</strong>
                        </div>
                    }
                }

                @if (_activeLocks.Count > 0)
                {
                    <div class="small text-muted mt-1">
                        Total locked: <strong>@_activeLocks.Sum(l => (long)l.Amount).ToString("N0") QU</strong>
                        across <strong>@_activeLocks.Count</strong> epoch@(_activeLocks.Count != 1 ? "s" : "")
                        @if (_activeLocks.Sum(l => (long)l.EstReward) > 0)
                        {
                            <br />
                            <span>Est. full reward: <strong class="text-success">+@_activeLocks.Sum(l => (long)l.EstReward).ToString("N0") QU</strong></span>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @* ── Tab navigation ── *@
    <ul class="nav nav-tabs mb-3">
        @foreach (var tab in _tabs)
        {
            <li class="nav-item">
                <a class="nav-link @(tab == _activeTab ? "active" : "")" href=""
                   @onclick="() => _activeTab = tab" @onclick:preventDefault>@tab</a>
            </li>
        }
    </ul>

    @* ── Tab content ── *@
    @switch (_activeTab)
    {
        case "Lock":
            <div class="card">
                <div class="card-body">
                    <p class="small text-muted">Lock QU into the QEarn smart contract to earn staking rewards.</p>
                    <div class="mb-3">
                        <label class="small text-muted">Amount to lock (QU)</label>
                        <input type="text" inputmode="numeric" class="form-control"
                               value="@FormatQu(_lockAmount)"
                               @onchange="e => _lockAmount = ParseQu(e.Value?.ToString())" />
                        @if (_balance != null)
                        {
                            <div class="d-flex gap-1 mt-1">
                                <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetLockPercent(25)">25%</button>
                                <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetLockPercent(50)">50%</button>
                                <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetLockPercent(100)">100%</button>
                            </div>
                        }
                        <div class="form-text">Full amount locked. No additional fee. Min 10,000,000 QU.</div>
                    </div>
                    <button class="btn btn-primary w-100" @onclick="Lock" disabled="@(_sending || _lockAmount <= 0)">
                        @(_sending ? "Locking..." : "Lock QU")
                    </button>
                </div>
            </div>
            break;

        case "Query":
            <div class="card">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="small text-muted">Query Function</label>
                        <select class="form-select" @bind="_queryFunc">
                            <option value="1">Lock Info Per Epoch</option>
                            <option value="2">User Locked Info</option>
                            <option value="3">State of Round</option>
                            <option value="4">User Lock Status (52-week bitmask)</option>
                            <option value="5">Ended Status</option>
                            <option value="6">Stats Per Epoch</option>
                            <option value="7">Burned &amp; Boosted Stats (global)</option>
                            <option value="8">Burned &amp; Boosted Stats Per Epoch</option>
                        </select>
                    </div>

                    @if (_queryFunc is 1 or 3 or 6 or 8)
                    {
                        <div class="mb-3">
                            <label class="small text-muted">Epoch</label>
                            <input type="number" class="form-control" min="0" @bind="_qEpoch" />
                        </div>
                    }
                    @if (_queryFunc is 2 or 4 or 5)
                    {
                        <div class="mb-3">
                            <label class="small text-muted">User Identity</label>
                            <AddressInput @bind-Value="_qIdentity" />
                        </div>
                    }
                    @if (_queryFunc == 2)
                    {
                        <div class="mb-3">
                            <label class="small text-muted">Epoch</label>
                            <input type="number" class="form-control" min="0" @bind="_qEpoch" />
                        </div>
                    }

                    <button class="btn btn-primary w-100" @onclick="RunQuery" disabled="@_querying">
                        @(_querying ? "Querying..." : "Query")
                    </button>

                    @if (_queryResult != null)
                    {
                        <div class="mt-3">
                            @foreach (var kv in _queryResult)
                            {
                                <div class="d-flex justify-content-between py-1 border-bottom small">
                                    <span class="text-muted">@kv.Key</span>
                                    <span class="mono text-end" style="word-break:break-all">@kv.Value</span>
                                </div>
                            }
                        </div>
                    }

                    @if (_lockStatusBits != null)
                    {
                        <div class="mt-3">
                            <label class="small text-muted">Lock Status (52 weeks, bit 0 = earliest)</label>
                            <div class="d-flex flex-wrap gap-1 mt-1">
                                @for (int i = 0; i < 52; i++)
                                {
                                    var bit = i;
                                    var locked = (_lockStatusBits.Value >> bit & 1) == 1;
                                    <span class="badge @(locked ? "bg-success" : "bg-secondary")"
                                          title="Week @(bit + 1)"
                                          style="width:22px; font-size:0.6rem; padding:2px 0">@(bit + 1)</span>
                                }
                            </div>
                            <div class="small text-muted mt-1">
                                <span class="badge bg-success">N</span> = locked &nbsp;
                                <span class="badge bg-secondary">N</span> = not locked
                            </div>
                        </div>
                    }
                </div>
            </div>
            break;
    }

    @* ── Result / error messages ── *@
    @if (_result != null)
    {
        <div class="alert alert-success mt-3 small">
            Transaction broadcast!
            <div class="mt-1"><TxHashDisplay Hash="@_result" ShowFull="true" /></div>
            <div class="mt-1">
                <a href="/history"><i class="bi bi-clock-history me-1"></i>Track in History</a>
            </div>
        </div>
    }
    @if (_error != null)
    {
        <div class="alert alert-danger mt-2 small">@_error</div>
    }
}

@code {
    private static readonly string[] _tabs = ["Lock", "Query"];
    private string _activeTab = "Lock";
    private bool _sending;
    private string? _result;
    private string? _error;
    private bool _disposed;
    private const int ContractIndex = 9;

    // Auto-query
    private bool _autoLoading;
    private List<ActiveLock> _activeLocks = [];
    private (ulong fullyUnlocked, ulong fullyRewarded, ulong earlyUnlocked, ulong earlyRewarded)? _autoEndedStatus;

    private record ActiveLock(uint Epoch, ulong Amount, int Week, int Remaining, ulong Yield, ulong EstReward,
        ulong EpochTotalLocked, ulong EpochCurrentLocked, ulong EpochBonusAmount);

    // Balance (for percent buttons)
    private long? _balance;

    // Lock
    private long _lockAmount;

    // Unlock (from summary)
    private uint? _unlockingEpoch;
    private ulong _unlockAmount;

    // Query
    private int _queryFunc = 1;
    private uint _qEpoch;
    private string? _qIdentity;
    private bool _querying;
    private List<KeyValuePair<string, string>>? _queryResult;
    private ulong? _lockStatusBits;

    protected override async Task OnInitializedAsync()
    {
        if (TickMonitor.IsConnected && TickMonitor.Epoch > 0)
            _qEpoch = (uint)TickMonitor.Epoch;

        if (Seed.HasSeed)
        {
            LoadBalance().FireAndForget();
            _autoLoading = true;
            try
            {
                var pk = Seed.Identity!.Value.PublicKey;
                var currentEpoch = TickMonitor.IsConnected ? TickMonitor.Epoch : 0u;
                if (currentEpoch == 0)
                {
                    try { currentEpoch = (await Backend.GetTickInfoAsync()).Epoch; } catch { }
                }
                if (_qEpoch == 0 && currentEpoch > 0)
                    _qEpoch = currentEpoch;

                // Query lock status bitmask (function 4)
                var lockInput = new GetUserLockStatusInput { User = pk }.ToBytes();
                var lockResult = await Backend.QuerySmartContractAsync(ContractIndex, 4, lockInput);
                if (lockResult.Length >= 8 && currentEpoch > 0)
                {
                    var ls = GetUserLockStatusOutput.FromBytes(lockResult);

                    var tasks = new List<(int WeeksLocked, uint LockEpoch, Task<byte[]> QueryTask)>();
                    for (int i = 1; i < 52; i++)
                    {
                        if ((ls.Status >> i & 1) == 1)
                        {
                            var lockEpoch = currentEpoch - (uint)i;
                            var amountInput = new GetUserLockedInfoInput { User = pk, Epoch = lockEpoch }.ToBytes();
                            tasks.Add((i, lockEpoch, Backend.QuerySmartContractAsync(ContractIndex, 2, amountInput)));
                        }
                    }
                    if ((ls.Status & 1) == 1)
                    {
                        var amountInput = new GetUserLockedInfoInput { User = pk, Epoch = currentEpoch }.ToBytes();
                        tasks.Add((0, currentEpoch, Backend.QuerySmartContractAsync(ContractIndex, 2, amountInput)));
                    }

                    if (tasks.Count > 0)
                    {
                        var yieldTasks = new Dictionary<uint, Task<byte[]>>();
                        foreach (var (_, lockEpoch, _) in tasks)
                        {
                            if (!yieldTasks.ContainsKey(lockEpoch))
                            {
                                var yieldInput = new GetLockInfoPerEpochInput { Epoch = lockEpoch }.ToBytes();
                                yieldTasks[lockEpoch] = Backend.QuerySmartContractAsync(ContractIndex, 1, yieldInput);
                            }
                        }

                        await Task.WhenAll(tasks.Select(t => t.QueryTask).Concat(yieldTasks.Values));

                        foreach (var (weeksLocked, lockEpoch, queryTask) in tasks)
                        {
                            ulong amount = 0;
                            try
                            {
                                var amountResult = queryTask.Result;
                                if (amountResult.Length >= 8)
                                    amount = GetUserLockedInfoOutput.FromBytes(amountResult).LockedAmount;
                            }
                            catch { }

                            ulong yield = 0, epochTotalLocked = 0, epochCurrentLocked = 0, epochBonus = 0;
                            try
                            {
                                if (yieldTasks.TryGetValue(lockEpoch, out var yt) && yt.Result.Length >= 40)
                                {
                                    var info = GetLockInfoPerEpochOutput.FromBytes(yt.Result);
                                    yield = info.Yield;
                                    epochTotalLocked = info.LockedAmount;
                                    epochCurrentLocked = info.CurrentLockedAmount;
                                    epochBonus = info.BonusAmount;
                                }
                            }
                            catch { }

                            var estReward = yield > 0 ? amount * yield / 10_000_000 : 0;
                            var remaining = 52 - weeksLocked;
                            _activeLocks.Add(new ActiveLock(lockEpoch, amount, weeksLocked, remaining, yield, estReward,
                                epochTotalLocked, epochCurrentLocked, epochBonus));
                        }
                        _activeLocks = _activeLocks.OrderBy(l => l.Epoch).ToList();
                    }
                }

                // Query ended status (function 5)
                var endedInput = new GetEndedStatusInput { User = pk }.ToBytes();
                var endedResult = await Backend.QuerySmartContractAsync(ContractIndex, 5, endedInput);
                if (endedResult.Length >= 32)
                {
                    var es = GetEndedStatusOutput.FromBytes(endedResult);
                    _autoEndedStatus = (es.FullyUnlockedAmount, es.FullyRewardedAmount, es.EarlyUnlockedAmount, es.EarlyRewardedAmount);
                }
            }
            catch { }
            finally { _autoLoading = false; }
        }
    }

    private async Task<uint> GetTick() =>
        await TransactionHelper.ResolveTargetTickAsync(Backend, TickMonitor, Settings);

    private async Task Broadcast(long amount, uint tick, ITransactionPayload payload, string desc)
    {
        var dest = QubicIdentity.FromPublicKey(QubicContracts.GetContractPublicKey(ContractIndex));
        _result = await TransactionHelper.BroadcastContractCallAsync(Backend, TxTracker, Seed, dest, amount, tick, payload, desc);
    }

    private async Task LoadBalance()
    {
        if (!Seed.HasSeed || Seed.Identity == null) return;
        try
        {
            var bal = await Backend.GetBalanceAsync(Seed.Identity.Value);
            _balance = bal.Amount;
        }
        catch { _balance = null; }
    }

    private void SetLockPercent(int pct)
    {
        if (_balance == null || _balance.Value <= 0) return;
        _lockAmount = _balance.Value * pct / 100;
        if (_lockAmount <= 0) _lockAmount = 1;
    }

    private async Task Lock()
    {
        _sending = true; _error = null; _result = null;
        try
        {
            if (_lockAmount <= 0) { _error = "Amount must be positive."; return; }
            var tick = await GetTick();
            var payload = new LockPayload();
            await Broadcast(_lockAmount, tick, payload, $"QEarn Lock {_lockAmount:N0} QU");
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _sending = false; }
    }

    private void StartUnlock(ActiveLock lk)
    {
        _unlockingEpoch = lk.Epoch;
        _unlockAmount = lk.Amount;
        _error = null;
        _result = null;
    }

    private async Task ConfirmUnlock(ActiveLock lk)
    {
        if (_unlockAmount <= 0 || _unlockAmount > lk.Amount)
        {
            _error = $"Amount must be between 1 and {lk.Amount:N0}.";
            return;
        }

        var earlyPct = GetEarlyUnlockRewardPercent(lk.Week);
        var amountLabel = _unlockAmount == lk.Amount ? $"{lk.Amount:N0}" : $"{_unlockAmount:N0} of {lk.Amount:N0}";
        var msg = earlyPct >= 100
            ? $"Unlock {amountLabel} QU from epoch {lk.Epoch}?\n\nThis lock has reached full maturity \u2014 you will receive 100% of the reward."
            : $"Unlock {amountLabel} QU from epoch {lk.Epoch}?\n\nThis is an early unlock (week {lk.Week}/52). You will only receive {earlyPct}% of the full reward.";
        if (!await JS.InvokeAsync<bool>("confirm", msg))
            return;

        _sending = true; _error = null; _result = null;
        try
        {
            var tick = await GetTick();
            var payload = new UnlockPayload
            {
                Amount = _unlockAmount, LockedEpoch = lk.Epoch
            };
            await Broadcast(0, tick, payload, $"QEarn Unlock {_unlockAmount:N0} QU from epoch {lk.Epoch}");
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _sending = false; _unlockingEpoch = null; }
    }

    private byte[] GetUserPk()
    {
        var err = IdentityValidation.Validate(_qIdentity);
        if (err != null) throw new Exception("Identity: " + err);
        return QubicIdentity.FromIdentity(_qIdentity!.Trim()).PublicKey;
    }

    private async Task RunQuery()
    {
        _querying = true; _error = null; _queryResult = null; _lockStatusBits = null;
        try
        {
            byte[] input;
            switch (_queryFunc)
            {
                case 1:
                    input = new GetLockInfoPerEpochInput { Epoch = _qEpoch }.ToBytes();
                    break;
                case 2:
                    input = new GetUserLockedInfoInput { User = GetUserPk(), Epoch = _qEpoch }.ToBytes();
                    break;
                case 3:
                    input = new GetStateOfRoundInput { Epoch = _qEpoch }.ToBytes();
                    break;
                case 4:
                    input = new GetUserLockStatusInput { User = GetUserPk() }.ToBytes();
                    break;
                case 5:
                    input = new GetEndedStatusInput { User = GetUserPk() }.ToBytes();
                    break;
                case 6:
                    input = new GetStatsPerEpochInput { Epoch = _qEpoch }.ToBytes();
                    break;
                case 7:
                    input = [];
                    break;
                case 8:
                    input = new GetBurnedAndBoostedStatsPerEpochInput { Epoch = _qEpoch }.ToBytes();
                    break;
                default: return;
            }

            var result = await Backend.QuerySmartContractAsync(ContractIndex, (uint)_queryFunc, input);
            _queryResult = ParseQueryResult(_queryFunc, result);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _querying = false; }
    }

    private static int GetEarlyUnlockRewardPercent(int w)
    {
        if (w >= 52) return 100;
        if (w >= 48) return 55;
        if (w >= 44) return 50;
        if (w >= 40) return 45;
        if (w >= 36) return 40;
        if (w >= 32) return 35;
        if (w >= 28) return 30;
        if (w >= 24) return 25;
        if (w >= 20) return 20;
        if (w >= 16) return 15;
        if (w >= 12) return 10;
        if (w >= 8) return 5;
        if (w >= 4) return 5;
        return 0;
    }

    private List<KeyValuePair<string, string>> ParseQueryResult(int func, byte[] data)
    {
        var list = new List<KeyValuePair<string, string>>();
        switch (func)
        {
            case 1 when data.Length >= 40:
                var li = GetLockInfoPerEpochOutput.FromBytes(data);
                list.Add(new("Locked Amount", $"{li.LockedAmount:N0} QU"));
                list.Add(new("Bonus Amount", $"{li.BonusAmount:N0} QU"));
                list.Add(new("Current Locked Amount", $"{li.CurrentLockedAmount:N0} QU"));
                list.Add(new("Current Bonus Amount", $"{li.CurrentBonusAmount:N0} QU"));
                list.Add(new("Yield", $"{(double)li.Yield / 100_000:F3}%"));
                break;

            case 2 when data.Length >= 8:
                var ui = GetUserLockedInfoOutput.FromBytes(data);
                list.Add(new("Locked Amount", $"{ui.LockedAmount:N0} QU"));
                break;

            case 3 when data.Length >= 4:
                var sr = GetStateOfRoundOutput.FromBytes(data);
                list.Add(new("State", sr.State.ToString()));
                break;

            case 4 when data.Length >= 8:
                var ls = GetUserLockStatusOutput.FromBytes(data);
                _lockStatusBits = ls.Status;
                var lockedCount = 0;
                for (int i = 0; i < 52; i++) if ((ls.Status >> i & 1) == 1) lockedCount++;
                list.Add(new("Status (raw)", ls.Status.ToString()));
                list.Add(new("Locked Weeks", $"{lockedCount} / 52"));
                break;

            case 5 when data.Length >= 32:
                var es = GetEndedStatusOutput.FromBytes(data);
                list.Add(new("Fully Unlocked Amount", $"{es.FullyUnlockedAmount:N0} QU"));
                list.Add(new("Fully Rewarded Amount", $"{es.FullyRewardedAmount:N0} QU"));
                list.Add(new("Early Unlocked Amount", $"{es.EarlyUnlockedAmount:N0} QU"));
                list.Add(new("Early Rewarded Amount", $"{es.EarlyRewardedAmount:N0} QU"));
                break;

            case 6 when data.Length >= 32:
                var sp = GetStatsPerEpochOutput.FromBytes(data);
                list.Add(new("Early Unlocked Amount", $"{sp.EarlyUnlockedAmount:N0} QU"));
                list.Add(new("Early Unlocked %", $"{(double)sp.EarlyUnlockedPercent / 100:F2}%"));
                list.Add(new("Total Locked Amount", $"{sp.TotalLockedAmount:N0} QU"));
                list.Add(new("Average APY", $"{(double)sp.AverageAPY / 100_000:F3}%"));
                break;

            case 7 when data.Length >= 48:
                var bb = GetBurnedAndBoostedStatsOutput.FromBytes(data);
                list.Add(new("Burned Amount", $"{bb.BurnedAmount:N0} QU"));
                list.Add(new("Avg Burned %", $"{(double)bb.AverageBurnedPercent / 100_000:F3}%"));
                list.Add(new("Boosted Amount", $"{bb.BoostedAmount:N0} QU"));
                list.Add(new("Avg Boosted %", $"{(double)bb.AverageBoostedPercent / 100_000:F3}%"));
                list.Add(new("Rewarded Amount", $"{bb.RewardedAmount:N0} QU"));
                list.Add(new("Avg Rewarded %", $"{(double)bb.AverageRewardedPercent / 100_000:F3}%"));
                break;

            case 8 when data.Length >= 48:
                var bp = GetBurnedAndBoostedStatsPerEpochOutput.FromBytes(data);
                list.Add(new("Burned Amount", $"{bp.BurnedAmount:N0} QU"));
                list.Add(new("Burned %", $"{(double)bp.BurnedPercent / 100_000:F3}%"));
                list.Add(new("Boosted Amount", $"{bp.BoostedAmount:N0} QU"));
                list.Add(new("Boosted %", $"{(double)bp.BoostedPercent / 100_000:F3}%"));
                list.Add(new("Rewarded Amount", $"{bp.RewardedAmount:N0} QU"));
                list.Add(new("Rewarded %", $"{(double)bp.RewardedPercent / 100_000:F3}%"));
                break;

            default:
                list.Add(new("Result", data.Length > 0 ? Convert.ToHexString(data) : "(empty)"));
                break;
        }
        return list;
    }

    private static string FormatQu(long amount) => amount > 0 ? amount.ToString("N0") : "";
    private static long ParseQu(string? text) =>
        long.TryParse(text?.Replace(",", "").Replace(" ", "").Trim(), out var v) && v >= 0 ? v : 0;

    public void Dispose()
    {
        _disposed = true;
    }
}
