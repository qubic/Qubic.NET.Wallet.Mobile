    async Task AssetOp()
    {
        _error = null; _result = null;
        if (_fees == null) { _error = "Fees not loaded."; return; }
        if (!QubicIdentity.TryParse(_aIssuer.Trim(), out _)) { _error = "Invalid asset issuer."; return; }
        if (string.IsNullOrWhiteSpace(_aName)) { _error = "Asset name required."; return; }
        if (_assetOp == "release" && !QubicIdentity.TryParse(_aDest.Trim(), out _)) { _error = "Invalid destination."; return; }

        // For deposit, check if management rights need to be transferred
        int managingContract = QubicContracts.Qx;
        ulong rightsFee = 0;
        bool transferRights = false;
        if (_assetOp == "deposit" && Seed.HasSeed && Seed.Identity != null)
        {
            try
            {
                var assets = await Backend.GetOwnedAssetsAsync(Seed.Identity.Value);
                var match = assets.FirstOrDefault(a =>
                    a.Data.IssuedAsset?.IssuerIdentity == _aIssuer.Trim()
                    && a.Data.IssuedAsset?.Name == _aName.Trim());
                if (match == null) { _error = "Asset not found in your owned assets."; return; }

                managingContract = (int)match.Data.ManagingContractIndex;
                if (managingContract == ContractIndex)
                    transferRights = false;
                else if (!QubicContracts.SupportsManagementRightsTransfer(managingContract))
                {
                    _error = $"Asset managed by {QubicContracts.FormatContract(managingContract)} — rights transfer not supported.";
                    return;
                }
                else
                {
                    transferRights = true;
                    rightsFee = StaticData.GetContractFee(managingContract, "Transfer Share Management Rights") ?? 0;
                }
            }
            catch (Exception ex) { _error = $"Failed to look up asset: {ex.Message}"; return; }
        }

        var issuerPk = QubicIdentity.FromIdentity(_aIssuer.Trim()).PublicKey;
        var assetNameUlong = AssetNameHelper.ToUlong(_aName.Trim());
        var asset = new Qubic.Core.Contracts.QubicAsset { Issuer = issuerPk, AssetName = assetNameUlong };
        var op = _assetOp; var vaultId = _aVaultId; var amount = (ulong)_aAmount; var name = _aName.Trim();
        var dest = _assetOp == "release" ? _aDest.Trim() : "";
        var doTransferRights = transferRights; var mgmtContract = managingContract; var mgmtFee = rightsFee;

        string confirmMsg = op switch
        {
            "deposit" when doTransferRights => $"Deposit {amount:N0} {name} to vault #{vaultId}?\n2 transactions: rights transfer{(mgmtFee > 0 ? $" ({mgmtFee:N0} QU)" : "")} + deposit ({_fees.Value.deposit:N0} QU)",
            "deposit" => $"Deposit {amount:N0} {name} to vault #{vaultId}?\nFee: {_fees.Value.deposit:N0} QU",
            "release" => $"Release {amount:N0} {name} from vault #{vaultId}?\nFee: {_fees.Value.release:N0} QU",
            "reset" => $"Reset asset releases for vault #{vaultId}?\nFee: {_fees.Value.reset:N0} QU",
            "revoke" => $"Revoke rights for {amount:N0} {name} shares?\nFee: 100 QU",
            _ => "Proceed?"
        };

        ShowConfirm("Asset Operation", confirmMsg, "Confirm", async () =>
        {
            _sending = true;
            try
            {
                var tick = await GetTick();
                switch (op)
                {
                    case "deposit":
                        if (doTransferRights)
                        {
                            var rightsPayload = QubicContracts.CreateManagementRightsPayload(mgmtContract, asset, (long)amount, ContractIndex);
                            var rightsDest = QubicIdentity.FromPublicKey(QubicContracts.GetContractPublicKey(mgmtContract));
                            var rightsTx = Seed.CreateAndSignTransaction(rightsDest, (long)mgmtFee, tick, rightsPayload);
                            var rightsResult = await Backend.BroadcastTransactionAsync(rightsTx);
                            TxTracker.Track(new TrackedTransaction
                            {
                                Hash = rightsResult.TransactionId, Source = Seed.Identity?.ToString() ?? "",
                                Destination = rightsDest.ToString(), Amount = (long)mgmtFee, TargetTick = tick,
                                InputType = rightsPayload.InputType, PayloadHex = Convert.ToHexString(rightsPayload.GetPayloadBytes()),
                                Description = $"Transfer Rights {name} x{amount} → MSVault",
                                RawData = Convert.ToHexString(rightsTx.GetRawBytes())
                            });
                            tick += 1;
                        }
                        var dp = new Qubic.Core.Contracts.Msvault.DepositAssetPayload { VaultId = vaultId, Asset = asset, Amount = amount };
                        await Broadcast((long)_fees!.Value.deposit, tick, dp, $"MSVault Deposit Asset: vault {vaultId}, {name} x{amount}");
                        break;
                    case "release":
                        var rp = new Qubic.Core.Contracts.Msvault.ReleaseAssetToPayload
                        {
                            VaultId = vaultId, Asset = asset, Amount = amount,
                            Destination = QubicIdentity.FromIdentity(dest).PublicKey
                        };
                        await Broadcast((long)_fees!.Value.release, tick, rp, $"MSVault Release Asset: vault {vaultId}, {name} x{amount}");
                        break;
                    case "reset":
                        await Broadcast((long)_fees!.Value.reset, tick,
                            new Qubic.Core.Contracts.Msvault.ResetAssetReleasePayload { VaultId = vaultId },
                            $"MSVault Reset Asset Release: vault {vaultId}");
                        break;
                    case "revoke":
                        var rvp = new Qubic.Core.Contracts.Msvault.RevokeAssetManagementRightsPayload { Asset = asset, NumberOfShares = (long)amount };
                        await Broadcast(100, tick, rvp, $"MSVault Revoke Mgmt Rights: {name} x{amount}");
                        break;
                }
            }
            catch (Exception ex) { _error = ex.Message; }
            finally { _sending = false; }
        });
    }

    // ── Query ──

    async Task RunQuery()
    {
        _querying = true; _error = null; _queryResult = null;
        try
        {
            byte[] input = _queryFunc switch
            {
                5 => new Qubic.Core.Contracts.Msvault.GetVaultsInput { PublicKey = GetQueryPk() }.ToBytes(),
                6 => new Qubic.Core.Contracts.Msvault.GetReleaseStatusInput { VaultId = _qVaultId }.ToBytes(),
                7 => new Qubic.Core.Contracts.Msvault.GetBalanceOfInput { VaultId = _qVaultId }.ToBytes(),
                8 => new Qubic.Core.Contracts.Msvault.GetVaultNameInput { VaultId = _qVaultId }.ToBytes(),
                10 => [],
                11 => new Qubic.Core.Contracts.Msvault.GetVaultOwnersInput { VaultId = _qVaultId }.ToBytes(),
                12 => new Qubic.Core.Contracts.Msvault.IsShareHolderInput { Candidate = GetQueryPk() }.ToBytes(),
                _ => throw new Exception("Unknown query")
            };
            var result = await Backend.QuerySmartContractAsync(ContractIndex, (uint)_queryFunc, input);
            _queryResult = ParseResult(_queryFunc, result);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _querying = false; }
    }

    byte[] GetQueryPk()
    {
        if (string.IsNullOrWhiteSpace(_qIdentity) || !QubicIdentity.TryParse(_qIdentity.Trim(), out var id))
            throw new Exception("Invalid identity.");
        return id.PublicKey;
    }

    List<KeyValuePair<string, string>> ParseResult(int func, byte[] data)
    {
        var list = new List<KeyValuePair<string, string>>();
        switch (func)
        {
            case 5 when data.Length >= 328:
                var gv = Qubic.Core.Contracts.Msvault.GetVaultsOutput.FromBytes(data);
                list.Add(new("Vaults", gv.NumberOfVaults.ToString()));
                for (int i = 0; i < (int)Math.Min(gv.NumberOfVaults, 8); i++)
                {
                    list.Add(new($"ID #{i + 1}", gv.VaultIds[i].ToString()));
                    list.Add(new($"Name #{i + 1}", FormatVaultName(gv.VaultNames[i])));
                }
                break;
            case 6 when data.Length >= 648:
                var rs = Qubic.Core.Contracts.Msvault.GetReleaseStatusOutput.FromBytes(data);
                list.Add(new("Status", rs.Status.ToString()));
                for (int i = 0; i < 16; i++)
                    if (rs.Amounts[i] > 0)
                        list.Add(new($"Release #{i + 1}", $"{rs.Amounts[i]:N0} QU → {PkToIdentity(rs.Destinations[i])}"));
                break;
            case 7 when data.Length >= 16:
                var bo = Qubic.Core.Contracts.Msvault.GetBalanceOfOutput.FromBytes(data);
                list.Add(new("Status", bo.Status.ToString()));
                list.Add(new("Balance", bo.Balance.ToString("N0")));
                break;
            case 8 when data.Length >= 40:
                var vn = Qubic.Core.Contracts.Msvault.GetVaultNameOutput.FromBytes(data);
                list.Add(new("Status", vn.Status.ToString()));
                list.Add(new("Name", FormatVaultName(vn.VaultName)));
                break;
            case 10 when data.Length >= 48:
                var fees = Qubic.Core.Contracts.Msvault.GetFeesOutput.FromBytes(data);
                list.Add(new("Register", fees.RegisteringFee.ToString("N0")));
                list.Add(new("Release", fees.ReleaseFee.ToString("N0")));
                list.Add(new("Reset", fees.ReleaseResetFee.ToString("N0")));
                list.Add(new("Holding", fees.HoldingFee.ToString("N0")));
                list.Add(new("Deposit", fees.DepositFee.ToString("N0")));
                list.Add(new("Burn", fees.BurnFee.ToString("N0")));
                break;
            case 11 when data.Length >= 536:
                var vo = Qubic.Core.Contracts.Msvault.GetVaultOwnersOutput.FromBytes(data);
                list.Add(new("Status", vo.Status.ToString()));
                list.Add(new("Owners", vo.NumberOfOwners.ToString()));
                for (int i = 0; i < (int)Math.Min(vo.NumberOfOwners, 16); i++)
                    list.Add(new($"Owner #{i + 1}", PkToIdentity(vo.Owners[i])));
                list.Add(new("Required Approvals", vo.RequiredApprovals.ToString()));
                break;
            case 12 when data.Length >= 8:
                var sh = Qubic.Core.Contracts.Msvault.IsShareHolderOutput.FromBytes(data);
                list.Add(new("Result", sh.Result != 0 ? "Yes" : "No"));
                break;
            default:
                list.Add(new("Raw", data.Length > 0 ? Convert.ToHexString(data) : "(empty)"));
                break;
        }
        return list;
    }

    // ── Helpers ──

    string PkToIdentity(byte[] pk)
    {
        try { return QubicIdentity.FromPublicKey(pk).ToString(); }
        catch { return Convert.ToHexString(pk); }
    }

    string FormatVaultName(byte[] raw)
    {
        if (raw == null || raw.Length == 0) return "(empty)";
        var trimmed = raw.AsSpan().TrimEnd((byte)0);
        if (trimmed.Length > 0)
        {
            try
            {
                var text = System.Text.Encoding.UTF8.GetString(trimmed);
                if (text.Length > 0 && !text.Any(c => char.IsControl(c) && c != '\t'))
                    return text;
            }
            catch { }
        }
        return PkToIdentity(raw);
    }

    bool _disposed;
    void OnTrackerChanged()
    {
        if (_disposed) return;
        InvokeAsync(() => { if (!_disposed) StateHasChanged(); });
    }

    public void Dispose()
    {
        _disposed = true;
        TxTracker.OnChanged -= OnTrackerChanged;
    }
