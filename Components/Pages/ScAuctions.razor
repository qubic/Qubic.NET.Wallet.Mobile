@page "/scauctions"
@using System.Buffers.Binary
@using Qubic.Core
@using Qubic.Core.Entities
@using Qubic.Core.Payloads
@inject QubicBackendService Backend
@inject SeedSessionService Seed
@inject TickMonitorService TickMonitor
@inject TransactionTrackerService TxTracker
@inject QubicSettingsService Settings

<h4>SC Auctions</h4>
<p class="text-muted small">Browse active contract share auctions, check bid status, and place bids.</p>
<div class="alert alert-info small py-1">This feature is in preview and may change in future updates.</div>

@* ── Tab bar ── *@
<div class="d-flex gap-1 mb-3 flex-wrap">
    @foreach (var tab in _tabs)
    {
        <button class="btn btn-sm @(tab == _activeTab ? "btn-primary" : "btn-outline-secondary")"
                @onclick="() => SetTab(tab)">@tab</button>
    }
</div>

@switch (_activeTab)
{
    case "Browse":
        <div class="card">
            <div class="card-header small fw-bold">Active Auctions</div>
            <div class="card-body">
                @if (_browseLoading)
                {
                    <div class="text-muted small"><span class="spinner-border spinner-border-sm me-1"></span> Loading active auctions...</div>
                }
                else if (_activeIpos is { Count: > 0 })
                {
                    @foreach (var ipo in _activeIpos)
                    {
                        <div class="card mb-2" style="cursor:pointer" @onclick="() => NavigateToStatus(ipo.ContractIndex)">
                            <div class="card-body py-2 px-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="fw-bold small">Contract #@ipo.ContractIndex</span>
                                        <span class="badge bg-secondary ms-1">@ipo.AssetName</span>
                                    </div>
                                    <span class="text-muted small">→</span>
                                </div>
                                <div class="small text-muted mt-1">
                                    <AddressDisplay Address="@QubicContracts.GetContractIdentity((int)ipo.ContractIndex).ToString()" TruncateChars="10" ShowCopy="false" />
                                </div>
                            </div>
                        </div>
                    }
                }
                else if (_activeIpos != null)
                {
                    <div class="text-muted small">No active auctions found.</div>
                }
            </div>
        </div>
        break;

    case "Status":
        <div class="card">
            <div class="card-header small fw-bold">Auction Status</div>
            <div class="card-body">
                <div class="mb-2">
                    <label class="small text-muted">Contract</label>
                    @if (_activeIpos is { Count: > 0 })
                    {
                        <select class="form-select form-select-sm mb-1" @bind="_statusContractIndex">
                            @foreach (var ipo in _activeIpos)
                            {
                                <option value="@ipo.ContractIndex">@ipo.ContractIndex -- @ipo.AssetName</option>
                            }
                        </select>
                    }
                    <input type="number" class="form-control form-control-sm" min="1" max="1023" @bind="_statusContractIndex"
                           placeholder="Or enter contract index" />
                </div>
                <button class="btn btn-primary w-100" @onclick="LookupStatus" disabled="@_statusLoading">
                    @(_statusLoading ? "Looking up..." : "Lookup")
                </button>

                @if (Backend.ActiveBackend != QueryBackend.DirectNetwork)
                {
                    <div class="alert alert-warning mt-2 small py-1 d-flex align-items-center justify-content-between">
                        <span>Requires DirectNetwork backend.</span>
                        <button class="btn btn-sm btn-warning ms-2" @onclick="SwitchToDirectNetwork">Switch</button>
                    </div>
                }

                @if (_ipoStatus != null)
                {
                    <div class="card mt-3 border-info">
                        <div class="card-header small fw-bold">Summary -- Contract @_statusContractIndex</div>
                        <div class="card-body py-2 small">
                            <div class="row g-1">
                                <div class="col-6"><span class="text-muted">Filled:</span> <span class="mono">@_filledSlots / 676</span></div>
                                <div class="col-6"><span class="text-muted">Min Bid:</span> <span class="mono">@(_filledSlots > 0 ? _minBid.ToString("N0") : "--")</span></div>
                                <div class="col-6"><span class="text-muted">Max Bid:</span> <span class="mono">@(_filledSlots > 0 ? _maxBid.ToString("N0") : "--")</span></div>
                                <div class="col-6"><span class="text-muted">Average:</span> <span class="mono">@(_filledSlots > 0 ? _avgBid.ToString("N0") : "--")</span></div>
                                <div class="col-12"><span class="text-muted">Total QU:</span> <strong class="mono">@(_filledSlots > 0 ? _totalBid.ToString("N0") + " QU" : "--")</strong></div>
                            </div>
                        </div>
                    </div>

                    @if (Seed.HasSeed && _mySlots.Count > 0)
                    {
                        <div class="card mt-3 border-primary">
                            <div class="card-header small fw-bold d-flex justify-content-between align-items-center">
                                <span>My Bids</span>
                                @if (_mySlots.Any(s => s.Price == _minBid))
                                {
                                    <span class="badge bg-warning text-dark">⚠ At Risk</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">✓ Safe</span>
                                }
                            </div>
                            <div class="card-body py-2 small">
                                <div class="mb-2 text-muted">
                                    @_mySlots.Count slot@(_mySlots.Count != 1 ? "s" : "") · Total: <strong class="mono">@_mySlots.Sum(s => s.Price).ToString("N0") QU</strong>
                                </div>
                                @foreach (var slot in _mySlots)
                                {
                                    var rank = _allSlots.FindIndex(s => s.Index == slot.Index) + 1;
                                    var atRisk = _filledSlots >= QubicConstants.NumberOfComputors && slot.Price == _minBid;
                                    <div class="border-bottom py-1">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="mono">Slot #@slot.Index</span>
                                            <span>
                                                @if (atRisk)
                                                {
                                                    <span class="badge bg-warning text-dark me-1">At Risk</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success me-1">Safe</span>
                                                }
                                                <span class="mono">#@rank</span>
                                            </span>
                                        </div>
                                        <div class="d-flex justify-content-between text-muted">
                                            <AddressDisplay Address="@slot.Identity" TruncateChars="10" ShowCopy="false" />
                                            <span class="mono">@slot.Price.ToString("N0") QU</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else if (Seed.HasSeed)
                    {
                        <div class="small text-muted mt-2">You have no bids in this auction.</div>
                    }

                    <div class="card mt-3">
                        <div class="card-header small fw-bold">All Bids (@_filledSlots)</div>
                        <div class="card-body py-2">
                            @if (_filledSlots > 0)
                            {
                                <div style="max-height: 300px; overflow-y: auto;">
                                    @foreach (var slot in _allSlots)
                                    {
                                        <div class="d-flex justify-content-between align-items-center border-bottom py-1 small">
                                            <span class="mono">#@slot.Index</span>
                                            <AddressDisplay Address="@slot.Identity" TruncateChars="8" ShowCopy="false" />
                                            <span class="mono">@slot.Price.ToString("N0")</span>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-muted small">No bids placed yet.</div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
        break;

    case "Bid":
        <div class="card">
            <div class="card-header small fw-bold">Place Auction Bid</div>
            <div class="card-body">
                @if (!Seed.HasSeed)
                {
                    <div class="alert alert-warning small">Enter a seed first.</div>
                }
                else
                {
                    <div class="mb-2">
                        <label class="small text-muted">Contract</label>
                        @if (_activeIpos is { Count: > 0 })
                        {
                            <select class="form-select form-select-sm mb-1" @bind="_bidContractIndex">
                                @foreach (var ipo in _activeIpos)
                                {
                                    <option value="@ipo.ContractIndex">@ipo.ContractIndex -- @ipo.AssetName</option>
                                }
                            </select>
                        }
                        <input type="number" class="form-control form-control-sm" min="1" max="1023" @bind="_bidContractIndex"
                               placeholder="Or enter contract index" />
                    </div>
                    <div class="mb-2">
                        <label class="small text-muted">Price per Share (QU)</label>
                        <input type="number" class="form-control form-control-sm" min="1" @bind="_bidPrice" />
                    </div>
                    <div class="mb-2">
                        <label class="small text-muted">Number of Shares (1-676)</label>
                        <input type="number" class="form-control form-control-sm" min="1" max="676" @bind="_bidQuantity" />
                    </div>
                    <div class="alert alert-info py-2 mb-2 d-flex justify-content-between align-items-center small">
                        <span>Total to pay:</span>
                        <strong class="mono">@((_bidPrice > 0 && _bidQuantity > 0 ? _bidPrice * _bidQuantity : 0).ToString("N0")) QU</strong>
                    </div>

                    @if (!_bidConfirmed)
                    {
                        <button class="btn btn-primary w-100" @onclick="PreviewBid" disabled="@(_sending || _bidPrice <= 0 || _bidQuantity <= 0)">
                            Preview Bid
                        </button>
                    }
                    else
                    {
                        <div class="alert alert-info small py-2">
                            <strong>Confirm:</strong> Bid <strong>@_bidQuantity</strong> share@(_bidQuantity != 1 ? "s" : "")
                            at <strong>@_bidPrice.ToString("N0") QU</strong> each
                            for contract <strong>@_bidContractIndex</strong>
                            (total: <strong>@((_bidPrice * _bidQuantity).ToString("N0")) QU</strong>)
                            at tick <strong>@_bidResolvedTick.ToString("N0")</strong>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-primary flex-fill" @onclick="SubmitBid" disabled="@_sending">
                                @(_sending ? "Sending..." : "Sign & Broadcast")
                            </button>
                            <button class="btn btn-outline-secondary flex-fill" @onclick="() => _bidConfirmed = false">Cancel</button>
                        </div>
                    }
                }
            </div>
        </div>
        break;
}

@if (_result != null)
{
    <div class="alert alert-success mt-3 small">
        Transaction broadcast! Tx ID: <TxHashDisplay Hash="@_result" ShowFull="true" />
        <div class="mt-1">
            <a href="/history">Transaction History</a>
        </div>
    </div>
}
@if (_error != null)
{
    <div class="alert alert-danger mt-2 small">@_error</div>
}

@code {
    private static readonly string[] _tabs = ["Browse", "Status", "Bid"];
    private string _activeTab = "Browse";
    private bool _sending;
    private string? _error;
    private string? _result;

    private void SetTab(string tab) { _activeTab = tab; _error = null; _result = null; }

    private void SwitchToDirectNetwork()
    {
        Backend.ActiveBackend = QueryBackend.DirectNetwork;
        StateHasChanged();
    }

    private async Task NavigateToStatus(uint contractIndex)
    {
        _statusContractIndex = contractIndex;
        _activeTab = "Status";
        _error = null; _result = null;
        await LookupStatus();
    }

    // -- Browse --
    private bool _browseLoading;
    private IReadOnlyList<IpoInfo>? _activeIpos;

    // -- Status --
    private uint _statusContractIndex = 1;
    private bool _statusLoading;
    private ContractIpo? _ipoStatus;
    private int _filledSlots;
    private long _minBid;
    private long _maxBid;
    private long _avgBid;
    private long _totalBid;
    private List<(int Index, string Identity, long Price)> _mySlots = [];
    private List<(int Index, string Identity, long Price)> _allSlots = [];

    // -- Bid --
    private uint _bidContractIndex = 1;
    private long _bidPrice;
    private int _bidQuantity = 1;
    private bool _bidConfirmed;
    private uint _bidResolvedTick;

    protected override async Task OnInitializedAsync()
    {
        _browseLoading = true;
        try
        {
            _activeIpos = await Backend.GetActiveIposAsync();
            if (_activeIpos is { Count: > 0 })
            {
                _statusContractIndex = _activeIpos[0].ContractIndex;
                _bidContractIndex = _activeIpos[0].ContractIndex;
            }
        }
        catch { }
        finally { _browseLoading = false; }
    }

    private async Task<uint> GetTick() =>
        await TransactionHelper.ResolveTargetTickAsync(Backend, TickMonitor, Settings);

    // -- Status Logic --

    private async Task LookupStatus()
    {
        _statusLoading = true; _error = null; _ipoStatus = null;
        _mySlots = []; _allSlots = [];
        _filledSlots = 0; _minBid = 0; _maxBid = 0; _avgBid = 0; _totalBid = 0;
        try
        {
            if (_statusContractIndex < 1 || _statusContractIndex > 1023)
            { _error = "Contract index must be between 1 and 1023."; return; }

            if (Backend.ActiveBackend != QueryBackend.DirectNetwork)
            { _error = "This feature requires the DirectNetwork backend."; return; }

            _ipoStatus = await Backend.GetIpoStatusAsync(_statusContractIndex);
            ComputeStatusSummary();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _statusLoading = false; }
    }

    private void ComputeStatusSummary()
    {
        if (_ipoStatus == null) return;

        var filled = new List<(int Index, string Identity, long Price)>();
        byte[]? myPk = Seed.HasSeed ? Seed.GetPublicKey() : null;
        _mySlots = [];

        for (int i = 0; i < QubicConstants.NumberOfComputors; i++)
        {
            var identity = _ipoStatus.GetParticipantIdentity(i);
            if (identity == null) continue;

            var price = _ipoStatus.Prices[i];
            filled.Add((i, identity.Value.ToString(), price));

            if (myPk != null && _ipoStatus.PublicKeys[i].AsSpan().SequenceEqual(myPk))
                _mySlots.Add((i, identity.Value.ToString(), price));
        }

        _filledSlots = filled.Count;
        if (filled.Count > 0)
        {
            _minBid = filled.Min(s => s.Price);
            _maxBid = filled.Max(s => s.Price);
            _totalBid = filled.Sum(s => s.Price);
            _avgBid = _totalBid / filled.Count;
        }

        _allSlots = filled.OrderByDescending(s => s.Price).ToList();
    }

    // -- Bid Logic --

    private async Task PreviewBid()
    {
        _error = null; _result = null;
        if (_bidContractIndex < 1 || _bidContractIndex > 1023)
        { _error = "Contract index must be between 1 and 1023."; return; }
        if (_bidPrice <= 0) { _error = "Price per share must be positive."; return; }
        if (_bidQuantity < 1 || _bidQuantity > 676) { _error = "Number of shares must be 1-676."; return; }

        try
        {
            _bidResolvedTick = await GetTick();
            _bidConfirmed = true;
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task SubmitBid()
    {
        _sending = true; _error = null;
        try
        {
            _bidResolvedTick = await GetTick();

            var data = new byte[16];
            BinaryPrimitives.WriteInt64LittleEndian(data.AsSpan(0), _bidPrice);
            BinaryPrimitives.WriteUInt16LittleEndian(data.AsSpan(8), (ushort)_bidQuantity);

            var dest = QubicContracts.GetContractIdentity((int)_bidContractIndex);
            var payload = new GenericContractPayload(0, data);
            _result = await TransactionHelper.BroadcastContractCallAsync(
                Backend, TxTracker, Seed, dest, 0, _bidResolvedTick, payload,
                $"SC Auction Bid: contract {_bidContractIndex}, {_bidQuantity} share(s) @ {_bidPrice:N0} QU");
            _bidConfirmed = false;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _sending = false; }
    }
}
