@page "/defi"

<h4>DeFi</h4>
<p class="text-muted small">Decentralized finance on Qubic.</p>

<div class="card">
    <a href="/qearn" class="qb-link-item">
        <div class="card-body d-flex align-items-center gap-3">
            <i class="bi bi-lock-fill" style="font-size:1.5rem;color:var(--qb-accent-cyan)"></i>
            <div>
                <div class="fw-bold">QEarn</div>
                <div class="small text-muted">Stake QU for weekly rewards over 52 weeks.</div>
            </div>
            <i class="bi bi-chevron-right ms-auto text-muted"></i>
        </div>
    </a>
</div>

<div class="card">
    <a href="/qswap" class="qb-link-item">
        <div class="card-body d-flex align-items-center gap-3">
            <i class="bi bi-arrow-left-right" style="font-size:1.5rem;color:var(--qb-accent-cyan)"></i>
            <div>
                <div class="fw-bold">QSwap</div>
                <div class="small text-muted">Swap tokens via automated market maker pools.</div>
            </div>
            <i class="bi bi-chevron-right ms-auto text-muted"></i>
        </div>
    </a>
</div>

<div class="card">
    <a href="/msvault" class="qb-link-item">
        <div class="card-body d-flex align-items-center gap-3">
            <i class="bi bi-safe-fill" style="font-size:1.5rem;color:var(--qb-accent-cyan)"></i>
            <div>
                <div class="fw-bold">MSVault</div>
                <div class="small text-muted">Multi-signature vaults with threshold approval.</div>
            </div>
            <i class="bi bi-chevron-right ms-auto text-muted"></i>
        </div>
    </a>
</div>

<div class="card">
    <a href="/qx" class="qb-link-item">
        <div class="card-body d-flex align-items-center gap-3">
            <i class="bi bi-graph-up-arrow" style="font-size:1.5rem;color:var(--qb-accent-cyan)"></i>
            <div>
                <div class="fw-bold">QX Exchange</div>
                <div class="small text-muted">Trade assets with ask/bid orders.</div>
            </div>
            <i class="bi bi-chevron-right ms-auto text-muted"></i>
        </div>
    </a>
</div>
