@* Live password-strength indicator backed by Qubic.Services VaultService.Estimate (zxcvbn). *@

@if (!string.IsNullOrEmpty(Password))
{
    var s = VaultService.Estimate(Password);
    var pct = (s.Score + 1) * 20;
    var bar = s.Score switch
    {
        0 => "bg-danger",
        1 => "bg-danger",
        2 => "bg-warning",
        3 => "bg-info",
        _ => "bg-success"
    };
    var label = s.Score switch
    {
        0 => "Very weak",
        1 => "Weak",
        2 => "Fair",
        3 => "Good",
        _ => "Strong"
    };

    <div class="password-strength mt-1">
        <div class="progress" style="height: 4px;">
            <div class="progress-bar @bar" role="progressbar"
                 style="width: @(pct)%;"
                 aria-valuenow="@s.Score" aria-valuemin="0" aria-valuemax="4"></div>
        </div>
        <div class="d-flex justify-content-between align-items-center mt-1">
            <span class="form-text small @LabelClass(s.Score)">@label</span>
            @if (!string.IsNullOrEmpty(s.CrackTimeDisplay) && s.Score >= 2)
            {
                <span class="form-text small text-muted">~@s.CrackTimeDisplay to crack</span>
            }
        </div>
        @if (!string.IsNullOrEmpty(s.Warning))
        {
            <div class="form-text small text-warning">@s.Warning</div>
        }
        @if (!s.IsAcceptable && s.Suggestions.Count > 0)
        {
            <ul class="form-text small text-muted mb-0 ps-3">
                @foreach (var suggestion in s.Suggestions)
                {
                    <li>@suggestion</li>
                }
            </ul>
        }
    </div>
}

@code {
    /// <summary>The password to evaluate. The meter renders nothing if this is empty.</summary>
    [Parameter] public string? Password { get; set; }

    private static string LabelClass(int score) => score switch
    {
        <= 1 => "text-danger",
        2 => "text-warning",
        3 => "text-info",
        _ => "text-success"
    };
}
