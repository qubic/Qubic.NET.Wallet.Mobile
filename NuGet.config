<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!--
      For local development against unpublished Qubic.* packages, add a local feed.
      In the Qubic.Net repo, run the publish script with the push-local flag.
      In this repo, run: dotnet nuget add source ~/.nuget/local-feed name qubic-local
      (Windows: dotnet nuget add source %USERPROFILE%\.nuget\local-feed name qubic-local)
    -->
  </packageSources>
</configuration>
